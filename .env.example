# Optional. Override the Vite base path for production builds.
# Use "/" for a user site like username.github.io, or "/repo-name/" for a project site.
VITE_BASE_PATH="/"

# Optional. Public site URL used for canonical and Open Graph tags.
# Example:
# VITE_SITE_URL="https://vyro1217.github.io/30birthday"
VITE_SITE_URL="https://vyro1217.github.io/30birthday"

# Optional. Override the full Open Graph image URL if you host it elsewhere.
VITE_OG_IMAGE_URL="https://vyro1217.github.io/30birthday/og-cover.png"
